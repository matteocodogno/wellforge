#!/usr/bin/env bash
# wellforge — install, check, and update the WellForge environment on a Mac.
#
#   wellforge setup     full setup: doctor --fix, repo clone/update, plugin install
#   wellforge doctor    check the environment (add --fix to install/upgrade tools)
#   wellforge update    update repo + tools + plugin
#   wellforge telegram  configure Telegram notifications (guided, step by step)
#   wellforge version   print CLI + checkout versions (also: --version, -v)
#
# Env overrides:
#   WELLFORGE_HOME  checkout location (default ~/.ai/wellforge; setup asks and
#                   remembers your choice; an enclosing checkout wins when the
#                   script is run from inside one)
#   WELLFORGE_REPO  git URL/path to clone from
#                   (default https://github.com/matteocodogno/wellforge.git)
set -euo pipefail

WELLFORGE_REPO="${WELLFORGE_REPO:-https://github.com/matteocodogno/wellforge.git}"
CONFIG_DIR="$HOME/.config/wellforge"
CONFIG_FILE="$CONFIG_DIR/config"           # remembers the chosen install location
TELEGRAM_ENV_FILE="$CONFIG_DIR/telegram.env"

# ─── ui ──────────────────────────────────────────────────────────────────────
if [ -t 1 ]; then
  GRN=$'\033[32m'; RED=$'\033[31m'; YLW=$'\033[33m'; DIM=$'\033[2m'; RST=$'\033[0m'
else
  GRN=""; RED=""; YLW=""; DIM=""; RST=""
fi
ok()   { printf "  %s✓%s %-18s %s\n" "$GRN" "$RST" "$1" "${2:-}"; }
bad()  { printf "  %s✗%s %-18s %s\n" "$RED" "$RST" "$1" "${2:-}"; }
warn() { printf "  %s!%s %-18s %s\n" "$YLW" "$RST" "$1" "${2:-}"; }
say()  { printf "%s\n" "$*"; }
die()  { printf "%serror:%s %s\n" "$RED" "$RST" "$*" >&2; exit 1; }

# ─── home resolution ─────────────────────────────────────────────────────────
script_repo() {
  # If this script lives inside a wellforge checkout, prefer it.
  local src dir
  src="${BASH_SOURCE[0]}"
  dir="$(cd "$(dirname "$src")/.." 2>/dev/null && pwd)" || return 1
  [ -f "$dir/.claude-plugin/marketplace.json" ] && echo "$dir"
}
# Resolution order: env var > enclosing checkout > saved choice > default ~/.ai
WELLFORGE_HOME="${WELLFORGE_HOME:-$(script_repo || true)}"
if [ -z "$WELLFORGE_HOME" ] && [ -f "$CONFIG_FILE" ]; then
  # shellcheck source=/dev/null
  . "$CONFIG_FILE"
fi
WELLFORGE_HOME="${WELLFORGE_HOME:-$HOME/.ai/wellforge}"

# ─── tool checks ─────────────────────────────────────────────────────────────
BREW_TOOLS=(mise uv gh jq)
FAILURES=0

check_brew() {
  if command -v brew >/dev/null; then ok "homebrew" "$(brew --version | head -1)"; else
    bad "homebrew" 'install first: /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'
    FAILURES=$((FAILURES+1)); return 1
  fi
}

check_tool() { # name [fix]
  local t="$1" fix="${2:-}"
  if command -v "$t" >/dev/null; then
    if [ -n "$fix" ] && brew outdated --quiet 2>/dev/null | grep -qx "$t"; then
      say "  ${DIM}upgrading ${t}…${RST}"; brew upgrade "$t" >/dev/null
      ok "$t" "upgraded → $("$t" --version 2>/dev/null | head -1)"
    else
      ok "$t" "$("$t" --version 2>/dev/null | head -1)"
    fi
  elif [ -n "$fix" ]; then
    say "  ${DIM}installing ${t}…${RST}"; brew install "$t" >/dev/null
    ok "$t" "installed"
  else
    bad "$t" "brew install $t"; FAILURES=$((FAILURES+1))
  fi
}

check_claude() { # [fix]
  if command -v claude >/dev/null; then ok "claude" "$(claude --version 2>/dev/null | head -1)"; return; fi
  if [ -n "${1:-}" ] && command -v npm >/dev/null; then
    say "  ${DIM}installing claude code via npm…${RST}"
    npm install -g @anthropic-ai/claude-code >/dev/null 2>&1 && { ok "claude" "installed"; return; }
  fi
  bad "claude" "npm i -g @anthropic-ai/claude-code  (or the desktop app)"
  FAILURES=$((FAILURES+1))
}

check_node() { # [fix] — npx is needed by the plugin's MCP servers
  if command -v npx >/dev/null; then ok "node/npx" "node $(node --version 2>/dev/null)"; return; fi
  if [ -n "${1:-}" ]; then
    say "  ${DIM}installing node via mise…${RST}"
    mise use -g node@22 >/dev/null 2>&1 && { ok "node/npx" "installed via mise"; return; }
  fi
  bad "node/npx" "mise use -g node@22  (MCP servers run via npx)"
  FAILURES=$((FAILURES+1))
}

check_docker() {
  if command -v docker >/dev/null; then
    if docker info >/dev/null 2>&1; then ok "docker" "daemon running"; else warn "docker" "installed but not running — start Docker Desktop"; fi
  else
    warn "docker" "not found — needed for local postgres/Testcontainers: brew install --cask docker-desktop"
  fi
}

check_gh_auth() {
  command -v gh >/dev/null || return 0
  # NOTE: `gh auth status` is not a local check — it reads the token from the
  # keychain and verifies it against the GitHub API. Distinguish the failure
  # modes instead of mislabeling them all as "not logged in".
  local out
  if out=$(gh auth status 2>&1); then
    ok "gh auth" "authenticated"
  elif echo "$out" | grep -q "Logged in to"; then
    warn "gh auth" "logged in, but verification failed (locked keychain / network / a second expired account?) — retry, or: gh auth status"
  elif grep -qs 'plugin run -- gh' "$HOME/.config/op/plugins.sh"; then
    # 1Password shell plugin: gh is aliased to `op plugin run -- gh` in the
    # INTERACTIVE shell only — raw gh (used by scripts, hooks, and Claude Code
    # sessions) has no credentials.
    warn "gh auth" "gh works in your shell via the 1Password plugin, but scripts & Claude Code call raw gh, which has no token — run 'gh auth login' once to cover automation too"
  else
    warn "gh auth" "not logged in — run: gh auth login (needed by the connections layer)"
  fi
}

check_copier() {
  command -v uvx >/dev/null || return 0
  if uvx copier --version >/dev/null 2>&1; then ok "copier (uvx)" "$(uvx copier --version 2>/dev/null)"; else
    warn "copier (uvx)" "uvx present but copier failed to run — check network/proxy"
  fi
}

check_repo() {
  if [ ! -f "$WELLFORGE_HOME/.claude-plugin/marketplace.json" ]; then
    bad "wellforge repo" "not at $WELLFORGE_HOME — run: wellforge setup (with WELLFORGE_REPO=<url>)"
    FAILURES=$((FAILURES+1)); return
  fi
  local desc; desc="$(git -C "$WELLFORGE_HOME" describe --tags --always 2>/dev/null || echo '?')"
  ok "wellforge repo" "$WELLFORGE_HOME ($desc)"

  # Checkout freshness vs origin — this is the channel where plugin features land
  # (commands/agents/skills), distinct from the brew CLI. A quiet fetch keeps the
  # recurring "am I up to date?" question honest. Skipped if no upstream / offline.
  local up behind
  up="$(git -C "$WELLFORGE_HOME" rev-parse --abbrev-ref '@{u}' 2>/dev/null)" || { warn "checkout" "no upstream tracked — can't check for plugin updates"; return; }
  git -C "$WELLFORGE_HOME" fetch --quiet 2>/dev/null || { warn "checkout" "couldn't reach $up (offline?) — skipped update check"; return; }
  behind="$(git -C "$WELLFORGE_HOME" rev-list --count 'HEAD..@{u}' 2>/dev/null || echo 0)"
  if [ "$behind" = "0" ]; then
    ok "checkout" "current with $up"
  else
    warn "checkout" "$behind commit(s) behind $up — plugin features may be stale; run: wellforge update (then /reload-plugins)"
  fi
}

check_plugin() {
  command -v claude >/dev/null || return 0
  if claude plugin marketplace list 2>/dev/null | grep -q "wellforge"; then ok "marketplace" "WellForge registered"; else
    bad "marketplace" "run: claude plugin marketplace add $WELLFORGE_HOME"; FAILURES=$((FAILURES+1))
  fi
  if claude plugin list 2>/dev/null | grep -q "wellforge"; then ok "plugin" "wellforge installed"; else
    bad "plugin" "run: claude plugin install wellforge@wellforge --scope user"; FAILURES=$((FAILURES+1))
  fi
}

# ─── telegram ────────────────────────────────────────────────────────────────
telegram_configured() {
  { [ -n "${TELEGRAM_BOT_TOKEN:-}" ] && [ -n "${TELEGRAM_CHAT_ID:-}" ]; } || [ -f "$TELEGRAM_ENV_FILE" ]
}

tg_api() { # token method [curl args…]
  local token="$1" method="$2"; shift 2
  curl -s --max-time 10 "https://api.telegram.org/bot${token}/${method}" "$@"
}

cmd_telegram() {
  say "Telegram notifications — guided setup"
  say "${DIM}The plugin's notify hook DMs you when Claude needs permission or is waiting.${RST}"
  say ""

  if telegram_configured && [ "${1:-}" != "--reconfigure" ]; then
    # shellcheck source=/dev/null
    [ -f "$TELEGRAM_ENV_FILE" ] && . "$TELEGRAM_ENV_FILE"
    say "Already configured ${DIM}($TELEGRAM_ENV_FILE)${RST}."
    printf "Send a test message now? [Y/n] "; read -r ans
    case "$ans" in n|N) ;; *) tg_test && return 0 || say "${YLW}test failed — re-running setup.${RST}";; esac
    printf "Reconfigure from scratch? [y/N] "; read -r ans
    case "$ans" in y|Y) ;; *) return 0 ;; esac
  fi

  # ── step 1: create a bot ──
  say ""
  say "${YLW}Step 1/3 — create your bot${RST}"
  say "  1. Open Telegram and start a chat with ${GRN}@BotFather${RST}  (opening now…)"
  say "  2. Send:  ${GRN}/newbot${RST}"
  say "  3. Pick any display name, then a username ending in ${DIM}bot${RST} (e.g. matteo_claude_bot)"
  say "  4. BotFather replies with an ${GRN}HTTP API token${RST} — copy it"
  command -v open >/dev/null && open "https://t.me/BotFather" 2>/dev/null
  say ""

  local token="" bot_user=""
  while [ -z "$bot_user" ]; do
    printf "Paste the bot token (input hidden): "
    read -rs token; printf "\n"
    [ -z "$token" ] && { say "  ${YLW}empty — try again (Ctrl-C to abort).${RST}"; continue; }
    bot_user=$(tg_api "$token" getMe | jq -r 'select(.ok) .result.username // empty')
    [ -z "$bot_user" ] && say "  ${RED}token rejected by the Telegram API${RST} — check for missing characters and retry."
  done
  ok "bot verified" "@$bot_user"

  # ── step 2: get your chat id ──
  say ""
  say "${YLW}Step 2/3 — link your account${RST}"
  say "  Open ${GRN}https://t.me/$bot_user${RST} (opening now…), press ${GRN}START${RST}, send any message."
  command -v open >/dev/null && open "https://t.me/$bot_user" 2>/dev/null
  printf "Press Enter once you've sent the message… "; read -r _

  local chat_id="" tries=0
  while [ -z "$chat_id" ] && [ $tries -lt 10 ]; do
    chat_id=$(tg_api "$token" getUpdates | jq -r '[.result[].message.chat.id] | last // empty')
    [ -z "$chat_id" ] && { tries=$((tries+1)); say "  ${DIM}no message yet — retrying ($tries/10)…${RST}"; sleep 2; }
  done
  if [ -z "$chat_id" ]; then
    die "no message received by @$bot_user. Make sure you pressed START and sent something, then re-run: wellforge telegram"
  fi
  ok "chat detected" "id $chat_id"

  # ── step 3: persist + verify ──
  say ""
  say "${YLW}Step 3/3 — save and verify${RST}"
  mkdir -p "$(dirname "$TELEGRAM_ENV_FILE")"
  {
    echo "# WellForge Telegram notifications — written by 'wellforge telegram'. Never commit."
    echo "export TELEGRAM_BOT_TOKEN=\"$token\""
    echo "export TELEGRAM_CHAT_ID=\"$chat_id\""
  } > "$TELEGRAM_ENV_FILE"
  chmod 600 "$TELEGRAM_ENV_FILE"
  ok "saved" "$TELEGRAM_ENV_FILE (chmod 600)"

  local rc="$HOME/.zshrc" src_line="[ -f \"$TELEGRAM_ENV_FILE\" ] && . \"$TELEGRAM_ENV_FILE\""
  if ! grep -qsF "$TELEGRAM_ENV_FILE" "$rc"; then
    printf "\n# WellForge Telegram notifications\n%s\n" "$src_line" >> "$rc"
    ok "shell wired" "source line appended to ~/.zshrc"
  else
    ok "shell wired" "~/.zshrc already sources it"
  fi

  export TELEGRAM_BOT_TOKEN="$token" TELEGRAM_CHAT_ID="$chat_id"
  tg_test || die "test message failed — check your network and re-run: wellforge telegram"
  say ""
  say "${GRN}done.${RST} ${DIM}Open a new terminal (or 'source ~/.zshrc') so Claude Code sessions inherit the vars.${RST}"
}

tg_test() {
  # shellcheck source=/dev/null
  [ -f "$TELEGRAM_ENV_FILE" ] && [ -z "${TELEGRAM_BOT_TOKEN:-}" ] && . "$TELEGRAM_ENV_FILE"
  local out
  out=$(tg_api "$TELEGRAM_BOT_TOKEN" sendMessage \
    -d "chat_id=${TELEGRAM_CHAT_ID}" \
    -d "text=🤖 WellForge: notifications are working." | jq -r '.ok')
  if [ "$out" = "true" ]; then ok "test message" "delivered — check Telegram"; return 0; fi
  bad "test message" "Telegram API returned an error"; return 1
}

# ─── commands ────────────────────────────────────────────────────────────────
cmd_doctor() {
  local fix=""
  [ "${1:-}" = "--fix" ] && fix=1
  FAILURES=0
  say "WellForge doctor ${DIM}(home: $WELLFORGE_HOME)${RST}"
  say ""
  say "tools:"
  check_brew || true
  if command -v brew >/dev/null; then
    for t in "${BREW_TOOLS[@]}"; do check_tool "$t" "$fix"; done
  fi
  check_node "$fix"
  check_claude "$fix"
  check_docker
  check_gh_auth
  check_copier
  say ""
  say "wellforge:"
  check_repo
  check_plugin
  if telegram_configured; then ok "telegram" "configured ($TELEGRAM_ENV_FILE)"; else
    warn "telegram" "not configured (optional) — run: wellforge telegram"
  fi
  say ""
  if [ "$FAILURES" -eq 0 ]; then
    say "${GRN}environment ready.${RST}"
  else
    say "${RED}$FAILURES check(s) failed.${RST} ${fix:+Some issues need manual action.}${fix:-Run: wellforge doctor --fix}"
    return 1
  fi
}

cmd_setup() {
  say "WellForge setup"
  command -v brew >/dev/null || die 'Homebrew first: /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'

  # 1. install location (asked once, remembered; Enter keeps the default)
  if [ -t 0 ] && [ ! -f "$WELLFORGE_HOME/.claude-plugin/marketplace.json" ]; then
    printf "Install location [%s]: " "$WELLFORGE_HOME"
    read -r ans
    if [ -n "$ans" ]; then
      case "$ans" in "~"*) ans="$HOME${ans#\~}" ;; esac
      case "$ans" in /*) WELLFORGE_HOME="$ans" ;; *) die "use an absolute path (got: $ans)" ;; esac
    fi
  fi
  mkdir -p "$CONFIG_DIR"
  echo "WELLFORGE_HOME=\"$WELLFORGE_HOME\"" > "$CONFIG_FILE"
  say "  ${DIM}home: $WELLFORGE_HOME (saved to $CONFIG_FILE)${RST}"

  # 2. repo
  if [ -f "$WELLFORGE_HOME/.claude-plugin/marketplace.json" ]; then
    say "  ${DIM}repo present — pulling latest…${RST}"
    git -C "$WELLFORGE_HOME" pull --ff-only 2>/dev/null || warn "repo" "pull skipped (no upstream yet)"
  else
    say "  ${DIM}cloning ${WELLFORGE_REPO}…${RST}"
    mkdir -p "$(dirname "$WELLFORGE_HOME")"
    git clone "$WELLFORGE_REPO" "$WELLFORGE_HOME" \
      || die "clone failed — private repo? run 'gh auth setup-git' or set WELLFORGE_REPO to an SSH URL"
  fi

  # 3. tools (doctor in fix mode does the installs/upgrades)
  cmd_doctor --fix || true

  # 4. marketplace + plugin (idempotent)
  if command -v claude >/dev/null; then
    claude plugin marketplace list 2>/dev/null | grep -q "wellforge" \
      || claude plugin marketplace add "$WELLFORGE_HOME"
    claude plugin list 2>/dev/null | grep -q "wellforge" \
      || claude plugin install wellforge@wellforge --scope user
  fi

  # 5. optional: Telegram notifications (interactive sessions only)
  if [ -t 0 ] && ! telegram_configured; then
    say ""
    printf "Enable Telegram notifications (DM when Claude needs permission / is waiting)? [y/N] "
    read -r ans
    case "$ans" in
      y|Y|yes) cmd_telegram ;;
      *) say "  ${DIM}skipped — run 'wellforge telegram' anytime.${RST}" ;;
    esac
  fi

  say ""
  cmd_doctor && say "
${GRN}done.${RST} Open a Claude Code session and verify:
  /plugin   → wellforge installed
  /mcp      → sequential-thinking, playwright, github
Next: docs/QUICKSTART.md — /wellforge:new for your first project."
}

cmd_update() {
  say "WellForge update"
  if [ -d "$WELLFORGE_HOME/.git" ]; then
    git -C "$WELLFORGE_HOME" pull --ff-only 2>/dev/null \
      && ok "repo" "$(git -C "$WELLFORGE_HOME" describe --tags --always 2>/dev/null)" \
      || warn "repo" "pull skipped (no upstream / local changes)"
  fi
  if command -v brew >/dev/null; then
    for t in "${BREW_TOOLS[@]}"; do
      brew outdated --quiet 2>/dev/null | grep -qx "$t" && { brew upgrade "$t" >/dev/null; ok "$t" "upgraded"; } || true
    done
  fi
  say "${DIM}plugin changes apply on the next Claude Code session (or /reload-plugins).${RST}"
  say "${DIM}note: this does not update the wellforge CLI itself — for that:${RST}"
  say "${DIM}  brew update && brew upgrade wellforge${RST}"
}

cmd_version() {
  # CLI version: derived from the brew Cellar path (no hardcoded constant to
  # forget at release time); a checkout run reports its git describe instead.
  local src ver="unknown"
  # resolve symlinks: brew links /opt/homebrew/bin/wellforge -> Cellar/…
  src="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
  src="$(cd "$(dirname "$src")" 2>/dev/null && pwd)" || true
  case "$src" in
    */Cellar/wellforge/*)
      ver="${src#*/Cellar/wellforge/}"; ver="${ver%%/*} (brew)" ;;
    *)
      local repo; repo="$(script_repo || true)"
      [ -n "$repo" ] && ver="$(git -C "$repo" describe --tags --always 2>/dev/null || echo '?') (running from checkout)" ;;
  esac
  say "wellforge $ver"
  if [ -f "$WELLFORGE_HOME/.claude-plugin/marketplace.json" ]; then
    local desc fresh=""
    desc="$(git -C "$WELLFORGE_HOME" describe --tags --always 2>/dev/null || echo '?')"
    # offline-safe freshness against the already-fetched ref (no network here)
    local behind; behind="$(git -C "$WELLFORGE_HOME" rev-list --count 'HEAD..@{u}' 2>/dev/null || echo 0)"
    [ "$behind" != "0" ] && fresh=" — ${behind} behind upstream, run: wellforge update"
    say "checkout:  $WELLFORGE_HOME ($desc)$fresh"
  else
    say "checkout:  none at $WELLFORGE_HOME — run: wellforge setup"
  fi
}

case "${1:-help}" in
  setup)    shift; cmd_setup "$@" ;;
  doctor)   shift; cmd_doctor "$@" ;;
  update)   shift; cmd_update "$@" ;;
  telegram) shift; cmd_telegram "$@" ;;
  version|--version|-v) cmd_version ;;
  *) sed -n '2,14p' "$0" | sed 's/^# \{0,1\}//' ;;
esac
