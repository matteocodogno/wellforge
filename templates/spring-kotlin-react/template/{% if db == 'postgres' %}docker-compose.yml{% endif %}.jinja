services:
  postgres:
    image: postgres:16
    environment:
      POSTGRES_DB: {{ project_slug }}
      POSTGRES_USER: {{ project_slug }}
      POSTGRES_PASSWORD: secret
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ project_slug }}"]
      interval: 5s
      timeout: 5s
      retries: 5
