{
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "requireCleanWorkingDir": true,
    "requireBranch": "main"
  },
  "npm": { "publish": false },
  "github": { "release": true, "releaseName": "v${version}" },
  "hooks": {
    "after:bump": "mise exec -- mvn -q -f backend/pom.xml versions:set -DnewVersion=${version} -DgenerateBackupPoms=false"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md"
    },
    "@release-it/bumper": {
      "out": ["frontend/package.json"]
    }
  }
}
