// settings-snippet.jsonc
// Merge this block into your project's .claude/settings.json (or ~/.claude/settings.json for global)
// JSON does not allow comments — remove all // lines before saving.
//
// What each key does:
//   enabledPlugins        — activates marketplace plugins; wellforge is installed via `claude plugin install`
//                           so it doesn't appear here. Only marketplace plugins use this syntax.
//   skipDangerousModePermissionPrompt — suppresses the "are you sure?" prompt when running in
//                           dangerous mode (--dangerously-skip-permissions). Set to true only on
//                           machines where YOU control who runs claude. Never set in shared CI.
//   attribution           — auto-populates commit/PR metadata. Fill in your preferred format strings.
//   worktree.baseRef      — base for isolated subagent worktrees. WellForge parallel dispatch
//                           (implement/orchestrate) runs ≥2 independent dev agents under
//                           `isolation: "worktree"`; "head" makes each worktree branch from the
//                           CURRENT HEAD (so it already has the spec, tasks.md, and tasks
//                           integrated earlier in the run) instead of the remote default branch.

{
  "worktree": {
    "baseRef": "head"
  },

  "enabledPlugins": {
    // Official marketplace plugins — install once, active globally
    "pyright-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": true
    // wellforge is installed as a local plugin via `claude plugin install ./wellforge-plugin`
    // It does not use the enabledPlugins syntax
  },

  "skipDangerousModePermissionPrompt": true,
  // ↑ Only set this if you regularly use --dangerously-skip-permissions on your local machine.
  //   Do NOT commit this to a shared repo or CI settings file.

  "attribution": {
    "commit": "",
    // ↑ Format string for commit messages generated by Claude, e.g.:
    //   "feat($scope): $message\n\nCo-authored-by: Claude <noreply@anthropic.com>"
    "pr": ""
    // ↑ Format string for PR descriptions, e.g.:
    //   "## Summary\n$summary\n\n## Changes\n$changes"
  }
}
